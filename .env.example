# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=giagri
DB_USER=postgres
DB_PASSWORD=123

# --- Pool de conexiones ---
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- App ---
APP_NAME=GIAGRI
APP_VERSION=0.1.0
APP_ENV=desarrollo
